# FinProof local development example.
# Copy this file to .env and replace placeholder values only when you need
# Prisma persistence, external AI providers, OCR, RAG, upload scanning, or S3.

# App/runtime
PORT="3000"
FINPROOF_AUTH_MODE="demo"
FINPROOF_REVIEW_STORE="mock"
FINPROOF_ENABLE_SAMPLE_DATA="false"

# Database. Required only when FINPROOF_REVIEW_STORE="prisma".
DATABASE_URL=""
DIRECT_URL=""
TEST_DATABASE_URL=""

# AI/model providers. Local demos can stay deterministic/mock-backed.
FINPROOF_MODEL_PROVIDER="deterministic"
OPENAI_API_KEY=""
GEMINI_API_KEY=""
FINPROOF_MODEL_DEFAULT_TEXT="gpt-5-mini"
FINPROOF_MODEL_ESCALATION_TEXT="gpt-5.4"
FINPROOF_MODEL_HIGHEST_PRECISION_TEXT="gpt-5.5"
FINPROOF_MODEL_MULTIMODAL="gemini-2.5-flash"
FINPROOF_MODEL_MULTIMODAL_ESCALATION="gemini-2.5-pro"

# Embeddings / knowledge retrieval.
FINPROOF_EMBEDDING_PROVIDER="deterministic"
FINPROOF_EMBEDDING_MODEL="text-embedding-3-small"
FINPROOF_EMBEDDING_ESCALATION_MODEL="text-embedding-3-large"
FINPROOF_EMBEDDING_ENDPOINT=""
FINPROOF_RAG_PROVIDER="deterministic"
FINPROOF_RAG_TOP_K="4"
FINPROOF_RAG_MIN_SCORE="0.72"
FINPROOF_RAG_MAX_CONTEXT_CHARS="6000"

# OCR and reranking.
FINPROOF_OCR_PROVIDER="deterministic"
FINPROOF_OCR_ENDPOINT=""
FINPROOF_OCR_API_KEY=""
FINPROOF_OCR_MODEL="gemini-2.5-flash-lite"
FINPROOF_OCR_MAX_INLINE_BYTES="20971520"
FINPROOF_RERANK_PROVIDER="deterministic"
FINPROOF_RERANK_ENDPOINT=""
FINPROOF_RERANK_API_KEY=""
FINPROOF_RERANK_MODEL="rerank-v3.5"
FINPROOF_RERANK_TOP_K="4"

# Background analysis worker.
FINPROOF_ANALYSIS_EXECUTION_MODE="inline"
FINPROOF_WORKER_TENANT_ID=""
FINPROOF_ANALYSIS_WORKER_ID="finproof-analysis-worker"

# Upload scanning.
FINPROOF_UPLOAD_SCAN_PROVIDER="deterministic"
FINPROOF_UPLOAD_SCAN_ENDPOINT=""
FINPROOF_UPLOAD_SCAN_API_KEY=""

# File storage. Local development keeps metadata locally; S3 is for production.
FINPROOF_STORAGE_ADAPTER="local-metadata"
FINPROOF_S3_BUCKET=""
AWS_REGION=""
